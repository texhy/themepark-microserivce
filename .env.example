# ── Application ───────────────────────────────────────────
APP_NAME=theme-park-msp
APP_ENV=development
HOST=0.0.0.0
PORT=8000

# ── Paths ─────────────────────────────────────────────────
# Local dev (relative to project root):
FAISS_INDEX_DIR=data/faiss_indexes
MODEL_DIR=models

# RunPod production (absolute, pointing to network volume):
# FAISS_INDEX_DIR=/runpod-volume/faiss_indexes
# MODEL_DIR=/runpod-volume/models

# ── GPU / ONNX Runtime ───────────────────────────────────
# "auto" = GPU if CUDAExecutionProvider available, else CPU
# 0 = force GPU, -1 = force CPU
FACE_CTX_ID=auto
DET_SIZE_WIDTH=640
DET_SIZE_HEIGHT=640

# ── Models ────────────────────────────────────────────────
INGEST_DET_MODEL=buffalo_l
QUERY_DET_MODEL=yolov8n-face
YOLOV8_FACE_ONNX=yolov8n-face.onnx

# ── Search defaults ───────────────────────────────────────
SIMILARITY_THRESHOLD=0.45
TOP_K=20

# ── CORS ──────────────────────────────────────────────────
# Comma-separated origins; * for dev, restrict for production
CORS_ORIGINS=*
